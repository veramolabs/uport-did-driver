{
  "name": "uport-did-driver",
  "version": "6.0.0",
  "private": "true",
  "description": "DID method driver for did:ethr, did:web, did:ens, did:peer",
  "main": "src/server.js",
  "exports": {
    ".": "./src/server.js"
  },
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "test": "vitest run",
    "format": "prettier --write '{src,docs,.github/workflows,!build}/**/*'",
    "getVersion": "echo \"console.log(require('./package.json').version)\" | node",
    "build": "docker build -t uport/uni-resolver-driver-did-uport:latest -t uport/uni-resolver-driver-did-uport:$(pnpm -s getVersion) .",
    "push": "docker push uport/uni-resolver-driver-did-uport:latest && docker push uport/uni-resolver-driver-did-uport:$(pnpm -s getVersion)",
    "release": "semantic-release --debug"
  },
  "author": "Christian Lundkvist",
  "contributors": [
    "Mircea Nistor <work@mirceanis.xyz>",
    "Andres Junge"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/veramolabs/uport-did-driver"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "did-resolver": "^5.0.1",
    "ens-did-resolver": "^1.0.4",
    "ethers": "^6.16.0",
    "ethr-did-resolver": "^13.0.0",
    "express": "^5.2.1",
    "express-actuator": "^1.8.4",
    "peer-did-resolver": "^2.0.0",
    "web-did-resolver": "^2.0.32"
  },
  "devDependencies": {
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/exec": "7.1.0",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.8",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.1",
    "prettier": "3.8.3",
    "semantic-release": "25.0.3",
    "supertest": "7.2.2",
    "vitest": "4.1.6"
  }
}
